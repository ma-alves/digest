{
  "name": "digest",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["handlers/shared"],
  "type": "module",
  "scripts": {
    "build:lambdas": "bash scripts/build-lambdas.sh",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "terraform -chdir=terraform plan",
    "tf:apply": "terraform -chdir=terraform apply",
    "tf:destroy": "terraform -chdir=terraform destroy",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "seed": "ts-node scripts/seed-subscribers.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "handlebars": "^4.7.8",
    "zod": "^3.23.0",
    "ulid": "^2.3.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^24.12.0",
    "@types/jest": "^30",
    "typescript": "~5.9.3",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2"
  }
}
