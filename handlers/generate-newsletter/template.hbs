<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Digest Newsletter</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { text-align: center; padding: 20px 0; border-bottom: 2px solid #e0e0e0; }
    .header h1 { color: #333; margin: 0; font-size: 24px; }
    .header p { color: #666; margin: 4px 0 0; font-size: 14px; }
    .article { background: white; margin: 16px 0; padding: 16px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
    .article h2 { margin: 0 0 8px; font-size: 18px; }
    .article h2 a { color: #1a73e8; text-decoration: none; }
    .article h2 a:hover { text-decoration: underline; }
    .article p { color: #444; margin: 0 0 8px; font-size: 14px; line-height: 1.5; }
    .article .meta { color: #888; font-size: 12px; }
    .article img { max-width: 100%; border-radius: 4px; margin-bottom: 8px; }
    .footer { text-align: center; padding: 20px; color: #888; font-size: 12px; }
    .footer a { color: #1a73e8; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Digest</h1>
      <p>{{generatedAt}}</p>
      <p>{{articleCount}} articles</p>
    </div>
    {{#each articles}}
    <div class="article">
      {{#if urlToImage}}<img src="{{urlToImage}}" alt="">{{/if}}
      <h2><a href="{{url}}">{{title}}</a></h2>
      {{#if description}}<p>{{description}}</p>{{/if}}
      <div class="meta">{{source.name}} · {{publishedAt}}</div>
    </div>
    {{/each}}
    <div class="footer">
      <p>You are receiving this email because you subscribed to Digest.</p>
      <p><a href="{{unsubscribeUrl}}">Unsubscribe</a></p>
    </div>
  </div>
</body>
</html>
