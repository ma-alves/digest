# NewsAPI Configuration
NEWSAPI_KEY=your-newsapi-key-here

# AWS Configuration (for local development)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Database Configuration (local development with docker-compose)
# When using RDS in production, this is set in ECS task definition
DATABASE_URL=jdbc:postgresql://localhost:5432/digest
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# GitHub Actions Secrets (for CI/CD deployment)
# Set these in your GitHub repository Settings → Secrets and variables → Actions
# AWS_ACCOUNT_ID: Your AWS account ID
# AWS_ACCESS_KEY_ID: CI/CD user access key
# AWS_SECRET_ACCESS_KEY: CI/CD user secret key
# ECR_REPOSITORY: digest
# ECS_CLUSTER_NAME: digest-cluster
# ECS_TASK_FAMILY: digest-task